# مفتاح OpenRouter الخاص بك (احصل عليه من https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# اختياري: معرّف النموذج على OpenRouter، اتركه كما هو للتوجيه التلقائي لأفضل نموذج متاح
# راجع القائمة الكاملة على https://openrouter.ai/models
OPENROUTER_MODEL=openrouter/auto

# اختياري: رابط موقعك عند النشر (يُستخدم في ترويسة الطلب لـ OpenRouter)
SITE_URL=http://localhost:3000
